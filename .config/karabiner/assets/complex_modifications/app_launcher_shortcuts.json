{
    "title": "App Launcher Shortcuts (Ghostty / Firefox / VS Code / Rectangle)",
    "rules": [
        {
            "description": "Remap Tab to Hyper key when held, Tab when tapped",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "tab",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "hyper",
                                "value": 1
                            }
                        }
                    ],
                    "to_after_key_up": [
                        {
                            "set_variable": {
                                "name": "hyper",
                                "value": 0
                            }
                        }
                    ],
                    "to_if_alone": [
                        {
                            "key_code": "tab"
                        }
                    ]
                }
            ]
        },
        {
            "description": "Hyper (Tab held) app shortcuts",
            "manipulators": [
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "variable_if",
                            "name": "hyper",
                            "value": 1
                        },
                        {
                            "type": "variable_if",
                            "name": "hyper_sublayer_w",
                            "value": 0
                        }
                    ],
                    "description": "Tab+Return -> Open Ghostty",
                    "from": {
                        "key_code": "return_or_enter",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "shell_command": "open -a Ghostty"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "variable_if",
                            "name": "hyper",
                            "value": 1
                        },
                        {
                            "type": "variable_if",
                            "name": "hyper_sublayer_w",
                            "value": 0
                        }
                    ],
                    "description": "Tab+B -> Open Firefox",
                    "from": {
                        "key_code": "b",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "shell_command": "open -a Firefox"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "variable_if",
                            "name": "hyper",
                            "value": 1
                        },
                        {
                            "type": "variable_if",
                            "name": "hyper_sublayer_w",
                            "value": 0
                        }
                    ],
                    "description": "Tab+C -> Open Visual Studio Code",
                    "from": {
                        "key_code": "c",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "shell_command": "open -a 'Visual Studio Code'"
                        }
                    ]
                }
            ]
        },
        {
            "description": "Hyper sublayer w (Rectangle window management)",
            "manipulators": [
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "variable_if",
                            "name": "hyper",
                            "value": 1
                        }
                    ],
                    "description": "Toggle Hyper sublayer w",
                    "from": {
                        "key_code": "w",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
